name: HDHive Checkin

on:
  workflow_dispatch:
  schedule:
    # 01:00 UTC = 09:00 Asia/Shanghai. The job then sleeps randomly.
    - cron: "0 1 * * *"

concurrency:
  group: hdhive-checkin
  cancel-in-progress: false

jobs:
  checkin:
    runs-on: ubuntu-latest
    timeout-minutes: 390
    env:
      HDHIVE_ACCOUNTS: ${{ secrets.HDHIVE_ACCOUNTS }}
      TG_BOT_TOKEN: ${{ secrets.TG_BOT_TOKEN }}
      TG_CHAT_ID: ${{ secrets.TG_CHAT_ID }}
      RANDOM_DELAY_SECONDS: 21600

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Random delay
        shell: bash
        run: |
          if [ "${{ github.event_name }}" = "schedule" ]; then
            delay=$(( RANDOM % RANDOM_DELAY_SECONDS ))
            echo "Sleeping ${delay}s before check-in..."
            sleep "$delay"
          else
            echo "Manual run: skip random delay."
          fi

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          python -m pip install playwright
          python -m playwright install --with-deps chromium

      - name: Run HDHive check-in
        run: python hdhive_checkin_multi.py
